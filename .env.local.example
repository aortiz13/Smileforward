# ============================================================
# Smile Forward — Variables de Entorno
# ============================================================
# Copia este archivo como .env.local y completa con tus valores:
#   cp .env.local.example .env.local
# ============================================================

# -----------------------------------------------------------
# SUPABASE (Obligatorias)
# Obtener desde: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# -----------------------------------------------------------
# SUPABASE SERVICE ROLE (Opcional — solo para admin server-side)
# ⚠️ NUNCA exponer al cliente. Solo se usa en Server Actions.
# -----------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# -----------------------------------------------------------
# RESEND (Opcional — para envío de emails)
# Obtener desde: https://resend.com/api-keys
# -----------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# APP URL (Opcional — para links, QR codes, etc.)
# -----------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ============================================================
# NOTA: La API Key de Google (GOOGLE_API_KEY) NO va aquí.
# Se configura como Secret en Supabase Edge Functions:
#   npx supabase secrets set GOOGLE_API_KEY=tu-api-key
# ============================================================
